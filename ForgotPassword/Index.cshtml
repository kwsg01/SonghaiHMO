@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Forgot Password - Songhai HMO</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        body { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; }
        .login-container { max-width: 450px; margin: 80px auto; }
    </style>
</head>
<body>
<div class="login-container">
    <div class="card">
        <div style="text-align: center;">
            <h1>🔐 Forgot Password</h1>
            <p>Enter your email address to receive a password reset link</p>
        </div>
        
        @if (ViewBag.Message != null)
        {
            <div class="info-box" style="background:#e8f5e9; border-left-color:#28a745;">
                <p>@ViewBag.Message</p>
            </div>
        }
        
        <form method="post" action="/ForgotPassword/SendResetLink">
            <input type="email" name="email" placeholder="Email Address" required>
            <button type="submit" class="btn-primary">Send Reset Link</button>
        </form>
        
        <div class="links">
            <a href="/Home/Login?role=admin">← Back to Login</a>
            <a href="/">Homepage</a>
        </div>
    </div>
</div>
</body>
</html>