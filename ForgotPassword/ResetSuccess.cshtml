@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Password Reset - Songhai HMO</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; }
        .login-container { max-width: 450px; margin: 80px auto; }
        .success-box { background: #e8f5e9; padding: 20px; border-radius: 8px; text-align: center; border-left: 4px solid #28a745; }
    </style>
</head>
<body>
<div class="login-container">
    <div class="card">
        <div style="text-align: center;">
            <h1>✅ Password Reset Successful</h1>
        </div>
        
        <div class="success-box">
            <p>Your password has been reset successfully.</p>
            <p>You can now login with your new password.</p>
        </div>
        
        <div class="links" style="margin-top: 20px;">
            <a href="/Home/Login?role=admin" class="btn-primary" style="display: inline-block; padding: 10px 20px;">Login Now</a>
        </div>
    </div>
</div>
</body>
</html>