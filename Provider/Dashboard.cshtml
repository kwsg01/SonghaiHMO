@{
    Layout = null;
    var providerName = ViewBag.ProviderName ?? "Provider";
    var claims = ViewBag.Claims as IEnumerable<SonghaiHMO.Models.Claim> ?? new List<SonghaiHMO.Models.Claim>();
}
<!DOCTYPE html>
<html>
<head>
    <title>Provider Dashboard - Songhai HMO</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        .stat-card {
            background: white;
            padding: 20px;
            border-radius: 12px;
            text-align: center;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        }
        .stat-card .number {
            font-size: 32px;
            font-weight: bold;
            color: #1a73e8;
        }
        .stat-card .currency {
            font-size: 24px;
            color: #28a745;
            font-weight: bold;
        }
        .status-pending { color: #ff9800; font-weight: bold; }
        .status-approved { color: #28a745; font-weight: bold; }
        .status-rejected { color: #dc3545; font-weight: bold; }
        .welcome-banner {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 30px;
            border-radius: 12px;
            margin-bottom: 20px;
        }
        .nav-links {
            margin-bottom: 20px;
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            background: white;
            padding: 15px 20px;
            border-radius: 12px;
        }
        .nav-links a {
            padding: 10px 20px;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 500;
            background: #f0f2f5;
            color: #333;
        }
        .nav-links a:hover {
            background: #1a73e8;
            color: white;
        }
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            flex-wrap: wrap;
            gap: 15px;
            background: white;
            padding: 15px 20px;
            border-radius: 12px;
        }
        .user-info {
            display: flex;
            gap: 15px;
            align-items: center;
        }
        .btn-danger {
            background: #dc3545;
            color: white;
            padding: 8px 15px;
            text-decoration: none;
            border-radius: 6px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        th, td {
            border: 1px solid #ddd;
            padding: 12px;
            text-align: left;
        }
        th {
            background: #1a73e8;
            color: white;
        }
        .table-container {
            overflow-x: auto;
        }
        @@media (max-width: 768px) {
            .stats-grid { grid-template-columns: repeat(2, 1fr); }
        }
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <h1>🏥 Provider Portal</h1>
        <div class="user-info">
            <span>👤 @providerName</span>
            <a href="/Provider/Logout" class="btn-danger">Logout</a>
        </div>
    </div>
    
    <div class="nav-links">
        <a href="/">🏠 Home</a>
        <a href="/Provider/Dashboard" style="background:#28a745; color:white;">📊 Dashboard</a>
        <a href="/Home/Portal">🔄 Switch Portal</a>
    </div>

    <div class="welcome-banner">
        <h2>Welcome, @providerName!</h2>
        <p>Manage and track your claims from this portal.</p>
    </div>

    <div class="stats-grid">
        <div class="stat-card"><h4>Total Claims</h4><div class="number">@ViewBag.TotalClaims</div></div>
        <div class="stat-card"><h4>Pending</h4><div class="number" style="color:#ff9800">@ViewBag.PendingClaims</div></div>
        <div class="stat-card"><h4>Approved</h4><div class="number" style="color:#28a745">@ViewBag.ApprovedClaims</div></div>
        <div class="stat-card"><h4>Rejected</h4><div class="number" style="color:#dc3545">@ViewBag.RejectedClaims</div></div>
        <div class="stat-card"><h4>Total Payout</h4><div class="currency">₦@ViewBag.TotalAmount.ToString("N0")</div></div>
    </div>

    <div class="card">
        <h2>📋 My Claims</h2>
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>ID</th><th>Enrollee</th><th>Service</th><th>Amount</th><th>Status</th><th>Date</th><th>Admin Notes</th>
                    </tr>
                </thead>
                <tbody>
                    @if (claims.Any())
                    {
                        foreach (var claim in claims)
                        {
                            <tr>
                                <td>@claim.Id</td
                                <td>@claim.Enrollee?.FullName</td
                                <td>@(claim.ServiceDescription?.Length > 50 ? claim.ServiceDescription.Substring(0,50)+"..." : claim.ServiceDescription)</td
                                <td>₦@claim.Amount.ToString("N0")</td
                                <td class="status-@claim.Status.ToLower()">@claim.Status</td
                                <td>@claim.SubmittedAt.ToString("yyyy-MM-dd")</td
                                <td>@(claim.AdminNotes ?? "-")</td
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="7" class="empty-state">No claims found</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
</body>
</html>