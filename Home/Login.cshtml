@{
    Layout = null;
    var role = ViewBag.Role as string ?? "admin";
}
<!DOCTYPE html>
<html>
<head>
    <title>Login - Songhai HMO</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }
        .role-badge {
            text-align: center;
            padding: 10px;
            border-radius: 50px;
            display: inline-block;
            margin-bottom: 20px;
            font-weight: bold;
        }
        .role-admin { background: #1a73e8; color: white; }
        .role-provider { background: #28a745; color: white; }
        .role-callcentre { background: #ff9800; color: white; }
        .role-enrollee { background: #6f42c1; color: white; }
        .error-msg {
            background: #ffebee;
            color: #c62828;
            padding: 10px;
            border-radius: 5px;
            margin-bottom: 15px;
            display: none;
        }
        .forgot-link {
            text-align: right;
            margin-top: 5px;
        }
        .forgot-link a {
            color: #1a73e8;
            text-decoration: none;
            font-size: 12px;
        }
        .forgot-link a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="card">
            <div style="text-align: center;">
                <h1>🏥 Songhai HMO</h1>
                <div id="roleBadge" class="role-badge role-@role">
                    @if (role == "admin")
                    {
                        <span>👨‍💼 Admin Portal Login</span>
                    }
                    else if (role == "provider")
                    {
                        <span>🏥 Provider Portal Login</span>
                    }
                    else if (role == "callcentre")
                    {
                        <span>📞 Call Centre Portal Login</span>
                    }
                    else
                    {
                        <span>👤 Enrollee Portal Login</span>
                    }
                </div>
            </div>
            
            <div class="info-box">
                @if (role == "admin")
                {
                    <strong>Admin Test Credentials:</strong>
                    <p>Username: admin<br>Password: admin123</p>
                    <p>Username: viewer<br>Password: viewer123 (Read-only)</p>
                }
                else if (role == "provider")
                {
                    <strong>Provider Test Credentials:</strong>
                    <p>Email: provider@test.com<br>Password: provider123</p>
                }
                else if (role == "callcentre")
                {
                    <strong>Call Centre Test Credentials:</strong>
                    <p>Email: callcentre@songhaihmo.com<br>Password: centre123</p>
                }
                else
                {
                    <strong>Enrollee Test Credentials:</strong>
                    <p>Username: JOHNDOE<br>Password: enrollee123</p>
                }
            </div>
            
            @if (TempData["Error"] != null)
            {
                <div class="error-msg" style="display:block;">@TempData["Error"]</div>
            }
            <div id="errorMsg" class="error-msg"></div>
            
            <!-- Login Form -->
            <div id="loginForm">
                <form method="post" action="/@(role == "admin" ? "Admin/Login" : (role == "provider" ? "Provider/Login" : (role == "callcentre" ? "CallCentre/Login" : "Enrollee/Login")))">
                    @if (role == "admin")
                    {
                        <input type="text" name="username" placeholder="Username" required>
                        <input type="password" name="password" placeholder="Password" required>
                    }
                    else if (role == "enrollee")
                    {
                        <input type="text" name="username" placeholder="Username" required>
                        <input type="password" name="password" placeholder="Password" required>
                    }
                    else
                    {
                        <input type="email" name="email" placeholder="Email" required>
                        <input type="password" name="password" placeholder="Password" required>
                    }
                    <button type="submit" id="loginBtn">Login</button>
                </form>
                <div class="forgot-link">
                    <a href="/ForgotPassword">Forgot Password?</a>
                </div>
            </div>
            
            <!-- Two-Factor Authentication Section -->
            <div id="twoFactorSection" style="display:none;">
                <hr style="margin: 20px 0;">
                <h3 style="text-align:center;">🔐 Two-Factor Authentication</h3>
                <p style="text-align:center;">Please enter the verification code sent to your email.</p>
                <input type="text" id="twoFactorCode" placeholder="Enter 6-digit code" style="text-align:center; font-size:20px; letter-spacing:5px;" maxlength="6">
                <button type="button" id="verifyTwoFactorBtn" class="btn-success" style="margin-top:10px;">Verify & Login</button>
                <button type="button" id="resendCodeBtn" class="btn-warning" style="margin-top:10px;">Resend Code</button>
                <input type="hidden" id="tempUserId" value="">
                <input type="hidden" id="tempUserType" value="">
                <input type="hidden" id="tempUserEmail" value="">
            </div>
            
            <div class="links">
                <a href="/Home/Portal">← Back to Portals</a>
                <a href="/">Homepage</a>
            </div>
        </div>
    </div>

    <script>
        var pendingLoginData = null;
        
        // Handle form submission with 2FA check
        document.querySelector('form')?.addEventListener('submit', async function(e) {
            e.preventDefault();
            
            var formData = new FormData(this);
            var actionUrl = this.action;
            
            try {
                var response = await fetch(actionUrl, {
                    method: 'POST',
                    body: formData
                });
                
                var result = await response.json();
                
                if (result.requiresTwoFactor) {
                    // Show 2FA section
                    pendingLoginData = result;
                    document.getElementById('tempUserId').value = result.userId;
                    document.getElementById('tempUserType').value = result.userType;
                    document.getElementById('tempUserEmail').value = result.email;
                    document.getElementById('loginForm').style.display = 'none';
                    document.getElementById('twoFactorSection').style.display = 'block';
                    
                    // Send verification code
                    await fetch('/TwoFactor/SendCode', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ userId: result.userId, email: result.email })
                    });
                    
                    Swal.fire({ icon: 'info', title: 'Verification Code Sent', text: 'A 6-digit code has been sent to your email', timer: 3000, showConfirmButton: false });
                } else if (result.success) {
                    window.location.href = result.redirectUrl;
                } else {
                    document.getElementById('errorMsg').innerText = result.message || 'Login failed';
                    document.getElementById('errorMsg').style.display = 'block';
                }
            } catch (error) {
                document.getElementById('errorMsg').innerText = 'Connection error: ' + error.message;
                document.getElementById('errorMsg').style.display = 'block';
            }
        });
        
        document.getElementById('verifyTwoFactorBtn')?.addEventListener('click', async function() {
            var code = document.getElementById('twoFactorCode').value;
            var userId = document.getElementById('tempUserId').value;
            
            if (!code || code.length !== 6) {
                Swal.fire({ icon: 'warning', title: 'Invalid Code', text: 'Please enter the 6-digit verification code' });
                return;
            }
            
            var response = await fetch('/TwoFactor/VerifyCode', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ userId: userId, code: code })
            });
            
            var result = await response.json();
            
            if (result.success) {
                // Complete login
                var loginResponse = await fetch('/TwoFactor/CompleteLogin', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ userId: userId, userType: document.getElementById('tempUserType').value })
                });
                var loginResult = await loginResponse.json();
                if (loginResult.success) {
                    window.location.href = loginResult.redirectUrl;
                }
            } else {
                Swal.fire({ icon: 'error', title: 'Invalid Code', text: result.message });
            }
        });
        
        document.getElementById('resendCodeBtn')?.addEventListener('click', async function() {
            var userId = document.getElementById('tempUserId').value;
            var email = document.getElementById('tempUserEmail').value;
            
            await fetch('/TwoFactor/SendCode', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ userId: userId, email: email })
            });
            
            Swal.fire({ icon: 'success', title: 'Code Sent!', text: 'A new verification code has been sent to your email', timer: 2000, showConfirmButton: false });
        });
    </script>
</body>
</html>